# Copy to local-credentials.env and fill in values.
# local-credentials.env is gitignored — never commit it.

# PostgreSQL (metrics schema — used by admin-metrics)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_SCHEMA=metrics

# Drill Admin API (drill4j-ui proxies /api here via setupProxy.js)
ADMIN_API_URL=http://localhost:8090

# drill4j-ui dev server
UI_DEV_URL=http://localhost:3000

# Metabase (reference only — export SQL/layout during implementation)
METABASE_URL=http://localhost:8095
METABASE_USER=
METABASE_PASSWORD=

# UI sign-in (create user via admin or use existing local account)
UI_TEST_USER=
UI_TEST_PASSWORD=
